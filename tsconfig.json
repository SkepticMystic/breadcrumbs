{
	"extends": "@tsconfig/svelte/tsconfig.json",

	"compilerOptions": {
		"types": ["svelte", "node", "obsidian-typings"],
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
		"allowJs": true,
		"noImplicitAny": true,
		"importHelpers": true,
		"isolatedModules": true,
		"strictNullChecks": true,
    "lib": [
      "DOM",
      "ES5",
      "ES6",
      "ES7"
    ]
	},
	"include": ["**/*.ts"]
}
